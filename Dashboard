<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Master: Live Edition</title>
    <script src="https://cdn.pubnub.com/sdk/javascript/pubnub.7.2.2.min.js"></script>
    <style>
        :root { --bg: #fff0f6; --panel: #ffffff; --magenta: #ff00ff; --soft-pink: #ffdeeb; }
        body { background: var(--bg); font-family: 'Georgia', serif; padding: 20px; color: var(--magenta); display: flex; flex-direction: column; align-items: center; }
        #dashboard { width: 100%; max-width: 1000px; }
        nav { margin-bottom: 20px; display: flex; gap: 10px; justify-content: center; }
        .tab-btn { padding: 10px 20px; border: 2px solid var(--magenta); background: white; border-radius: 50px; cursor: pointer; font-weight: bold; }
        .tab-btn.active { background: var(--magenta); color: white; }
        .view-section { display: none; }
        .view-section.active { display: block; }
        section, .card { background: white; padding: 20px; border-radius: 20px; border: 2px solid var(--soft-pink); margin-bottom: 20px; }
        .main-btn { background: var(--magenta); color: white; border: none; padding: 12px; border-radius: 10px; cursor: pointer; width: 100%; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; }
        .pfp { width: 60px; height: 60px; border-radius: 50%; object-fit: cover; }
        .sk-card { border: 2px solid var(--magenta); }
    </style>
</head>
<body>

<div id="dashboard">
    <nav>
        <button class="tab-btn active" onclick="showTab('home')">Home</button>
        <button class="tab-btn" onclick="showTab('sidekicks')">Sidekicks</button>
        <button class="tab-btn" onclick="showTab('settings')">System Setup</button>
    </nav>

    <div id="home" class="view-section active">
        <section>
            <h1 id="sys-name-disp">My System</h1>
            <div id="my-front-display" class="grid"></div>
            <button class="main-btn" style="margin-top:15px;" onclick="broadcastFront()">📡 Broadcast Front to Friends</button>
        </section>
    </div>

    <div id="sidekicks" class="view-section">
        <section>
            <h3>Add Sidekick Channel</h3>
            <p style="font-size: 0.8rem;">Ask your friend for their "Channel Name"</p>
            <input type="text" id="sk-channel-input" placeholder="e.g. blossom-system-123">
            <button class="main-btn" onclick="addSidekick()">Add Sidekick</button>
        </section>
        <div id="sidekick-list" class="grid"></div>
    </div>

    <div id="settings" class="view-section">
        <section>
            <h3>System Settings</h3>
            <input type="text" id="sys-name-input" placeholder="System Name">
            <input type="text" id="sync-channel-id" placeholder="Create Secret Sync Channel Name (e.g. your-name-123)">
            <button class="main-btn" onclick="saveSettings()">Save System Info</button>
        </section>
    </div>
</div>

<script>
    // Initialize PubNub
    const pubnub = new PubNub({
        publishKey: 'pub-c-49033f92-c286-4f40-848e-ef86903366c8', // Demo keys
        subscribeKey: 'sub-c-10336714-386d-4950-9d04-1c6670a48530',
        userId: "user-" + Math.random()
    });

    let state = JSON.parse(localStorage.getItem('liveSysData')) || { name: "New System", channel: "", members: [] };
    let skList = JSON.parse(localStorage.getItem('skList')) || [];

    function saveSettings() {
        state.name = document.getElementById('sys-name-input').value;
        state.channel = document.getElementById('sync-channel-id').value;
        localStorage.setItem('liveSysData', JSON.stringify(state));
        alert("Settings Saved!");
        refreshUI();
    }

    function broadcastFront() {
        if(!state.channel) return alert("Please set a Sync Channel in Settings first!");
        const payload = {
            name: state.name,
            fronters: state.members.filter(m => m.isFronting)
        };
        pubnub.publish({ channel: state.channel, message: payload });
        alert("Front sent to cloud!");
    }

    function addSidekick() {
        const chan = document.getElementById('sk-channel-input').value;
        if(!chan) return;
        if(!skList.includes(chan)) skList.push(chan);
        localStorage.setItem('skList', JSON.stringify(skList));
        refreshUI();
    }

    function refreshSidekick(chan) {
        pubnub.subscribe({ channels: [chan] });
        pubnub.addListener({
            message: (m) => {
                if(m.channel === chan) {
                    const card = document.getElementById(`card-${chan}`);
                    card.innerHTML = `<h4>${m.message.name}</h4>` + 
                        m.message.fronters.map(f => `<p>🌸 ${f.name}</p>`).join('');
                }
            }
        });
        // Request a fresh update
        pubnub.history({ channel: chan, count: 1 }, (status, response) => {
            if (response.messages.length) {
                const data = response.messages[0].entry;
                document.getElementById(`card-${chan}`).innerHTML = `<h4>${data.name}</h4>` + 
                    data.fronters.map(f => `<p>🌸 ${f.name}</p>`).join('');
            }
        });
    }

    function refreshUI() {
        document.getElementById('sys-name-disp').innerText = state.name;
        const list = document.getElementById('sidekick-list');
        list.innerHTML = '';
        skList.forEach(chan => {
            list.innerHTML += `<div class="card sk-card" id="card-${chan}">
                <p>Channel: ${chan}</p>
                <button class="tab-btn" onclick="refreshSidekick('${chan}')">🔄 Refresh Status</button>
            </div>`;
        });
    }

    function showTab(t) {
        document.querySelectorAll('.view-section').forEach(s => s.classList.remove('active'));
        document.getElementById(t).classList.add('active');
    }

    refreshUI();
</script>
</body>
</html>
